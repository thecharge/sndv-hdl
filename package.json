{
  "name": "@ts2v/workspace",
  "version": "2.0.0",
  "private": true,
  "description": "Production-grade TypeScript to SystemVerilog workspace",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean && rm -rf .turbo",
    "dev": "turbo run dev --parallel",
    "format": "bunx biome format . --write",
    "format:check": "bunx biome format .",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "quality": "bun run typecheck && bun run lint && bun run test && bun run build",
    "prepare": "husky",
    "toolchain:image:build": "bash scripts/build-toolchain-image.sh",
    "toolchain:image:build:docker": "TS2V_CONTAINER_RUNTIME=docker bash scripts/build-toolchain-image.sh",
    "toolchain:image:build:podman": "TS2V_CONTAINER_RUNTIME=podman bash scripts/build-toolchain-image.sh",
    "flash:tang20k": "bun run packages/toolchain/src/entrypoints/flash-tang20k.ts",
    "compile:example": "bun run apps/cli/src/index.ts compile examples/hardware/tang_nano_20k_blinker.ts --board boards/tang_nano_20k.board.json --out .artifacts/tang20k"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "bun-types": "1.3.10",
    "turbo": "^2.1.3",
    "typescript": "^5.8.2"
  }
}
