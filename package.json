{
  "name": "@ts2v/workspace",
  "version": "2.0.0",
  "private": true,
  "description": "Production-grade TypeScript to SystemVerilog workspace",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean && rm -rf .turbo",
    "dev": "turbo run dev --parallel",
    "format": "bunx biome format . --write",
    "format:check": "bunx biome format .",
    "lint": "turbo run lint",
    "security:scan": "bun run security:scan:secrets && bun run security:scan:risky",
    "security:scan:history": "bash scripts/check-history-secrets.sh",
    "security:scan:risky": "bash scripts/check-risky-patterns.sh",
    "security:scan:secrets": "bash scripts/check-secrets.sh",
    "test": "turbo run test",
    "test:root": "bun test tests/class-compiler.test.ts tests/uvm-flow.test.ts tests/codegen.test.ts tests/integration.test.ts tests/lexer.test.ts tests/parser.test.ts tests/typechecker.test.ts",
    "test:uvm": "bash scripts/run-uvm-testbench.sh",
    "test:coverage": "bash scripts/check-coverage.sh",
    "typecheck": "turbo run typecheck",
    "quality": "bun run typecheck && bun run lint && bun run test && bun run test:root && bun run test:coverage && bun run build",
    "prepare": "husky",
    "toolchain:image:build": "bash scripts/build-toolchain-image.sh",
    "toolchain:image:build:docker": "TS2V_CONTAINER_RUNTIME=docker bash scripts/build-toolchain-image.sh",
    "toolchain:image:build:podman": "TS2V_CONTAINER_RUNTIME=podman bash scripts/build-toolchain-image.sh",
    "flash:tang20k": "bun run packages/toolchain/src/entrypoints/flash-tang20k.ts",
    "compile:example": "bun run apps/cli/src/index.ts compile examples/hardware/tang_nano_20k/blinker/blinker.ts --board boards/tang_nano_20k.board.json --out .artifacts/tang20k",
    "verify": "bash scripts/run-verify.sh"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "bun-types": "1.3.10",
    "husky": "^9.1.7",
    "turbo": "^2.1.3",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "serialport": "13.0.0"
  }
}